.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Generated documents
deliverables/docx/*.docx
deliverables/pdf/*.pdf
deliverables/pptx/

# Generated reports and temporary files
consistency/reports/*
consistency/exports/
consistency/logs/
tmp/
packages/

# Generated literature workspaces (a student's own topic may hold private
# notes). Keep the bundled PSC example that ships as a public demo.
literature/*/
!literature/psc/

# Private source material
assets/library/files/pdfs/*
assets/library/inbox/pdfs/*
assets/library/registry/*
assets/data/raw/*
assets/data/processed/*
source/front_matter/*.docx

# Keep placeholder docs
!assets/library/files/pdfs/README.md
!assets/library/inbox/pdfs/README.md
!assets/library/registry/README.md
!consistency/reports/.gitkeep

# Local/editor files
.claude/launch.json
.vscode/
.idea/
.DS_Store
Thumbs.db
